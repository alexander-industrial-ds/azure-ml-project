# =============================================================================
#  config.env.example — TEMPLATE
#  Copy this file to config.env and fill in your values.
#
#    cp config.env.example config.env
#    nano config.env
#
#  Then run:  ./setup.sh --config config.env
#
#  ⚠️  NEVER commit config.env — it is in .gitignore.
#      This example file IS safe to commit (no real values).
# =============================================================================

# ── Azure identifiers ─────────────────────────────────────────────────────────
SUBSCRIPTION_ID="<your-subscription-id>"
RESOURCE_GROUP="rg-azureml-project"
LOCATION="eastus2"

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_ACCOUNT="mlstorage<your-suffix>"   # 3-24 lowercase alphanumeric, globally unique
DATA_CONTAINER="mldata"

# ── Azure ML Workspace ────────────────────────────────────────────────────────
WORKSPACE_NAME="mlw-project"

# ── Compute ───────────────────────────────────────────────────────────────────
CI_NAME="ci-dev"
CLUSTER_NAME="aml-cluster"
CLUSTER_SIZE="STANDARD_DS11_V2"

# ── Azure ML Resources ────────────────────────────────────────────────────────
DATASTORE_NAME="project_datastore"
ENVIRONMENT_NAME="project-training-env"

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_REPO_URL="https://github.com/<your-org>/<your-repo>"
PROJECT_DIR="./project"
